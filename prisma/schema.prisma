generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  password         String
  role             Role              @default(RECEPTIONIST)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  technicianNotes  TechnicianNote[]
  repairOrders     RepairOrder[]     @relation("CreatedBy")
  statusHistory    RepairStatusHistory[] @relation("ChangedBy")
}

enum Role {
  ADMIN
  TECHNICIAN
  RECEPTIONIST
}

model Customer {
  id          String   @id @default(cuid())
  fullName    String
  phone1      String
  phone2      String?
  address     String
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  devices     Device[]
}

model Device {
  id                String         @id @default(cuid())
  customerId        String
  customer          Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  category          DeviceCategory
  brand             String
  model             String
  serialNumber      String?
  physicalCondition String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  repairOrders      RepairOrder[]
}

enum DeviceCategory {
  ORDINATEUR_PORTABLE
  ORDINATEUR_BUREAU
  IMPRIMANTE
  TELEPHONE
  TABLETTE
  RESEAU
  AUTRE
}

model RepairOrder {
  id            String             @id @default(cuid())
  dossierNumber String             @unique // ITB-yyyy-xxxx
  deviceId      String
  device        Device             @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  description   String
  urgency       Urgency            @default(MOYEN)
  accessories   String[]           // Chargeur, Batterie, etc. array of Strings
  createdById   String
  createdBy     User               @relation("CreatedBy", fields: [createdById], references: [id])
  status        Status             @default(RECU)
  receptionDate DateTime           @default(now())
  signatureUrl  String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  statusHistory RepairStatusHistory[]
  notes         TechnicianNote[]
}

enum Urgency {
  FAIBLE
  MOYEN
  ELEVEE
}

enum Status {
  RECU
  DIAGNOSTIC
  EN_ATTENTE_CLIENT
  EN_COURS
  REPARE
  LIVRE
  ANNULE
}

model RepairStatusHistory {
  id            String      @id @default(cuid())
  repairOrderId String
  repairOrder   RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  status        Status
  changedAt     DateTime    @default(now())
  changedById   String
  changedBy     User        @relation("ChangedBy", fields: [changedById], references: [id])
}

model TechnicianNote {
  id            String      @id @default(cuid())
  repairOrderId String
  repairOrder   RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  technicianId  String
  technician    User        @relation(fields: [technicianId], references: [id])
  note          String
  createdAt     DateTime    @default(now())
}
